            "life_defining_events": [
              {
                "age_when": 31,
                "event": "Shortly after her daughter Ananya was born, Priya discovered a news report about a popular baby formula brand being recalled due to bacterial contamination \u2014 a brand she had almost chosen based on a neighbor's casual recommendation.",
                "lasting_impact": "This near-miss hardened her instinct to never delegate high-stakes decisions to others uncritically, fueling her tension between trusting peers and needing to verify everything herself before acting."
              },
              {
                "age_when": 28,
                "event": "When furnishing their first owned flat in Powai, Priya outsourced the interior decisions to a designer recommended by a colleague, only to receive poorly fitted cabinetry and mismatched materials that cost an additional \u20b980,000 to correct.",
                "lasting_impact": "The experience calcified her low tolerance for delegating quality-sensitive decisions, making her the primary driver of all household and family purchases regardless of the time cost to herself."
              },
              {
                "age_when": 24,
                "event": "During her postgraduate management program, a behavioral finance module demonstrated through classroom simulations how peer-validated decisions consistently outperformed individual hunches in controlled scenarios, leaving a strong impression on her.",
