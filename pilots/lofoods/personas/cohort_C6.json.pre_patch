      ],
      "contextual_examples_replaced": [
        {
          "original": "I'm sitting in a one-bedroom in Koramangala",
          "replacement": "I'm sitting in a one-bedroom in Whitefield",
          "attribute_source": "life_story.age_28 (explicit lease in Whitefield)"
        },
        {
          "original": "reading Reddit threads, cross-checking reviews on tech forums",
