          "replacement": "a ThinkPad purchase",
          "attribute_source": "life_stories.age_23 + location.city (Bengaluru tech worker culture)"
        },
        {
          "original": "forums, asking friends",
          "replacement": "tech forums and Reddit threads, messaging friends",
          "attribute_source": "life_stories.age_23 (actual research behavior documented) + location.city (Bengaluru metro digital literacy)"
        },
        {
          "original": "people I trust are using",
          "replacement": "colleagues from the office, people who paid their own money",
          "attribute_source": "employment.full_time + location.city (Bengaluru corporate context) + behavioral_summary.peer_influenced"
        }
      ],
      "validation_status": {
        "cr1_isolation": "pass",
        "cr2_stereotype_audit": "not_run",
