        "IndianRedditors (localized peer network reference)"
      ],
      "contextual_examples_replaced": [
        {
          "original": "a supermarket or generic review site",
          "replacement": "91mobiles for phone research",
          "attribute_source": "location.city: Chennai, income_bracket: middle"
        },
