        "Flipkart (Indian e-commerce platform, mass-market alternative)",
        "Decathlon (metro-accessible sports/home goods retail, quality-focused brand Bengaluru professionals trust)"
      ],
      "contextual_examples_replaced": [
        {
          "original": "long-form reviews, user forums",
          "replacement": "GSMArena teardowns, detailed Amazon reviews, tech forums on Reddit",
          "attribute_source": "location.city + education.postgraduate + employment.tech"
        },
        {
