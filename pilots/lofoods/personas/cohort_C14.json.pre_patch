            "life_defining_events": [
              {
                "age_when": 24,
                "event": "During his final semester of postgraduate studies in Pune, he bought a cheap off-brand laptop to save money, only to have it fail mid-thesis submission, forcing him to pay more to recover data and rush-buy a reliable replacement.",
                "lasting_impact": "Cemented his quality_vs_budget tension \u2014 he now defaults to researching thoroughly and spending more upfront on durable products rather than risking costly failures."
              },
              {
