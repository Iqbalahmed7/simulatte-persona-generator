        "life_stories": [
          {
            "title": "The Contaminated Formula Scare",
            "when": "age 32",
            "event": "Shortly after her daughter Mira was born, Priya discovered through a trusted mothers' WhatsApp group that a popular baby formula brand had reported quality inconsistencies in certain batches \u2014 a warning she would never have seen in any advertisement.",
            "lasting_impact": "This incident cemented her habit of sourcing critical product information exclusively from peer networks rather than brands, and made quality non-negotiable for anything entering her home, regardless of cost."
          },
          {
            "title": "The Outsourced Project Disaster",
            "when": "age 27",
            "event": "While managing her first major analytics project at a Mumbai consulting firm, Priya delegated a key data validation module to a junior team member, only to discover critical errors during the client presentation that she had not personally reviewed.",
            "lasting_impact": "The professional humiliation hardwired a deep resistance to delegation, driving her compulsion to personally oversee decisions \u2014 from household purchases to her daughter's pediatric appointments \u2014 even at significant personal cost."
          },
          {
            "title": "The Postgraduate Scholarship Decision",
            "when": "age 24",
            "event": "Priya turned down a higher-paying industry job offer to complete her postgraduate degree in applied statistics, methodically spreadsheet-modeling the five-year income and career trajectory of both paths before choosing the safer, credential-building route.",
            "lasting_impact": "This deliberate, data-driven choice over immediate reward reinforced her low risk tolerance and analytical identity, establishing a lifelong pattern of prioritizing long-term security over short-term gains."
          }
        ],
