        "life_stories": [
          {
            "title": "The Internship Budget Reckoning",
            "when": "age 23",
            "event": "During his first paid internship in Pune, he tracked every rupee in a spreadsheet after realizing his stipend barely covered rent, groceries, and a single weekend outing per month.",
            "lasting_impact": "This forced discipline hardwired a price-first mindset \u2014 he still compares unit costs before buying anything, from groceries to software subscriptions."
          },
          {
            "title": "Postgraduate Thesis Vindication",
            "when": "age 26",
            "event": "His master's thesis on supply chain optimization was initially dismissed by one panel member, so he spent three weeks rebuilding his statistical models from scratch and presented a rebuttal that earned him distinction.",
            "lasting_impact": "The experience cemented his trust in his own analytical process over external opinions, reinforcing a deeply self-reliant decision-making style."
          },
          {
            "title": "The Bengaluru Apartment Compromise",
            "when": "age 28",
            "event": "He toured twelve apartments across Koramangala and HSR Layout, building a weighted scoring sheet, before settling alone in a mid-range 1BHK that sacrificed proximity to friends for a lower rent and better commute math.",
            "lasting_impact": "Living solo on a moderate income keeps the tension between wanting a premium lifestyle and accepting practical constraints a daily reality he actively manages."
          }
        ],
