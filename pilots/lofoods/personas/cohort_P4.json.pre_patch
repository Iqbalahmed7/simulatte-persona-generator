          "original": "Living in Delhi with two kids",
          "replacement": "Living in Dwarka with two kids",
          "attribute_source": "life_story.age_31 (3BHK purchase location)"
        },
        {
          "original": "I read reviews, cross-check community forums, compare total cost",
          "replacement": "I read Amazon reviews and IndiaStack community forums, cross-check BigBasket unit prices against D-Mart",
          "attribute_source": "behavioral_summary (reviews + community) + location.city (Delhi metro shopping platforms)"
        }
      ],
      "validation_status": {
        "cr1_isolation": "pass",
        "cr2_stereotype_audit": "not_run",
        "cr3_cultural_realism": "not_run",
