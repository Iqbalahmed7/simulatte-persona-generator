        },
        {
          "original": "expert opinions",
          "replacement": "expert opinions from The Hindu's analysis or ICRA reports",
          "attribute_source": "behavioral_summary.influenced_by_experts + location.metro_institution_access"
        }
      ],
      "validation_status": {
