        "life_stories": [
          {
            "title": "The Scholarship Budget Reckoning",
            "when": "age 22",
            "event": "During her postgraduate program at a Mumbai university, she received a partial merit scholarship but still had to manage a tight monthly stipend of \u20b98,000, meticulously tracking every rupee in a spreadsheet she built herself.",
            "lasting_impact": "That experience hardwired her to anchor every major purchase decision on price first, and to trust her own calculations over anyone else's recommendations \u2014 habits that persist even now with a stable dual income."
          },
          {
            "title": "The Apartment Upgrade That Stalled",
            "when": "age 31",
            "event": "After her daughter was born, she and her husband identified a larger 3BHK flat in Powai they desperately wanted, but the EMI projections left too thin a safety margin, so she built a 24-month savings plan and chose to wait instead of stretching.",
            "lasting_impact": "The experience crystallized her moderate risk tolerance \u2014 she learned she could hold aspiration without acting on it impulsively, but also felt the quiet ache of deferral that now underlies her ongoing tension between wanting more and spending carefully."
          },
          {
            "title": "The Nutrition Panic That Passed",
            "when": "age 29",
            "event": "A routine blood test during her pregnancy flagged borderline glucose levels, sending her into weeks of anxious research into gestational diabetes and elimination diets including a brief flirtation with low-carb eating.",
            "lasting_impact": "Follow-up tests confirmed everything normalized, leaving her with residual health-consciousness but no lasting dietary restriction \u2014 explaining why her diabetic concern and keto adherence both remain near-negligible today."
          }
        ],
