            "life_defining_events": [
              {
                "age_when": 28,
                "event": "As a junior accounts manager at a textile firm in Delhi, he discovered a \u20b94 lakh discrepancy in vendor invoices that his supervisor had missed for six months; he spent three weekends cross-verifying every ledger entry himself before reporting it.",
                "lasting_impact": "Cemented his conviction that careful self-reliance and analytical verification are more dependable than trusting others' judgment, forming the core of his trust-in-self orientation."
              },
              {
                "age_when": 35,
                "event": "After years of saving, he came within weeks of finalizing a housing loan for a two-bedroom flat in Rohini, only to have the bank revise the interest terms at the last moment, forcing him to withdraw and continue renting in his joint family home.",
                "lasting_impact": "The near-miss instilled a persistent tension between his desire to secure independent property and the financial reality of a middle household income, keeping price sensitivity and cautious aspiration central to every major decision."
              },
              {
                "age_when": 48,
                "event": "When his elder son secured admission to a private engineering college, the first-semester fee of \u20b91.8 lakh arrived the same month as a major home appliance breakdown and his wife's medical bills, forcing him to liquidate a recurring deposit early at a penalty.",
                "lasting_impact": "The experience reinforced moderate risk tolerance \u2014 he vowed never again to have all savings locked in illiquid instruments \u2014 and made price and value-for-money the dominant filter for every household expenditure thereafter."
              }
            ],
