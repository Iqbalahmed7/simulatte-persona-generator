          "original": "Pune (generic regional reference)",
          "replacement": "Mumbai university (location-specific, matches location.city and education.postgraduate)",
          "attribute_source": "location.city, education.level"
        },
        {
          "original": "the building (generic)",
          "replacement": "Powai towers / her building in a Mumbai metro locality",
          "attribute_source": "location.city, income_bracket.upper-middle, life_story.age_31"
