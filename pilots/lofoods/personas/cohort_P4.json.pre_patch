            "source": "proxy"
          },
          "switching_propensity": {
            "band": "medium",
            "description": "You weigh options thoughtfully before switching, balancing familiarity with openness to change.",
            "source": "proxy"
          },
          "objection_profile": [
            {
              "objection_type": "price_vs_value",
              "likelihood": "high",
              "severity": "friction"
