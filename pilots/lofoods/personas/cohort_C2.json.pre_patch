        "life_stories": [
          {
            "title": "The Ration Card Crisis",
            "when": "age 31",
            "event": "When her husband's textile shop suffered losses during a local flood in Lucknow, Meena had to stretch a 2,000-rupee weekly budget across six family members for nearly four months, learning to prioritize dal and rice over anything else.",
            "lasting_impact": "This cemented her instinct to always choose the cheapest reliable option first, making price her non-negotiable primary filter for every household purchase."
          },
          {
            "title": "Her Mother-in-Law's Hospital Stay",
            "when": "age 38",
            "event": "Meena's mother-in-law was diagnosed with a kidney infection and hospitalized for three weeks, leaving Meena as the sole person managing meals, school runs, and elder care simultaneously while also working her part-time tailoring orders.",
            "lasting_impact": "The experience locked her identity firmly into the caregiver role and deepened her social trust exclusively within family, making her skeptical of outside advice or unfamiliar products."
          },
          {
            "title": "The Branded Atta Disappointment",
            "when": "age 42",
            "event": "A neighbor convinced Meena to try an expensive multigrain atta claiming it was healthier, and she spent 180 rupees on a bag that her family refused to finish because of the unfamiliar taste, wasting money the household couldn't afford.",
            "lasting_impact": "This reinforced her resistance to health trend claims like gluten-free or specialty diets, and made her deeply cautious about trading proven, budget-friendly staples for anything marketed as premium."
          }
        ],
