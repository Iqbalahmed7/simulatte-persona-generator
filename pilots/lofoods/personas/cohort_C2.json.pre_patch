            "life_defining_events": [
              {
                "age_when": 25,
                "event": "While planning her wedding in Kochi, she insisted on a quality catering spread despite her family's tight budget, and watched relatives quietly judge the modest venue while praising the food \u2014 a painful lesson in choosing battles.",
                "lasting_impact": "Cemented her belief that quality in the right places matters more than quantity everywhere, fueling her ongoing tension between spending wisely and refusing to compromise on what truly matters."
              },
              {
                "age_when": 29,
                "event": "When her infant daughter spiked a high fever at 2 AM, she called her mother in Thrissur before the doctor, and her mother's calm guidance got them through the night without an emergency visit.",
                "lasting_impact": "Deepened her trust in family over institutions, and reinforced her low risk tolerance \u2014 she now over-prepares for every household decision, especially anything involving her child's health or safety."
              },
              {
                "age_when": 27,
                "event": "She brought an elaborate home-cooked Kerala fish curry to an office potluck only to have a colleague loudly avoid it claiming gluten concerns, which confused her since the dish had none \u2014 the moment felt dismissive of her effort.",
                "lasting_impact": "Left her skeptical of trendy dietary labels like gluten-free or keto, viewing them as largely performative for people around her, and reinforced her preference for traditional, wholesome home cooking."
              }
