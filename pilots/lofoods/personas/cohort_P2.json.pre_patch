            "life_defining_events": [
              {
                "age_when": 31,
                "event": "A cardiologist at Apollo Chennai incorrectly interpreted her husband's ECG and recommended an unnecessary procedure; she caught the error by independently cross-referencing medical literature and getting a second opinion.",
                "lasting_impact": "This episode hardened her trust orientation toward self-reliance \u2014 she now personally verifies all significant decisions rather than delegating them to experts, professionals, or family members."
              },
              {
                "age_when": 38,
                "event": "While heading a quality audit team at her firm, she watched a peer manager's project collapse because he had loosely delegated critical process checks; her own meticulously self-managed deliverable earned her the senior director role.",
                "lasting_impact": "The incident reinforced her low social orientation and deep aversion to delegation, cementing her belief that quality outcomes require personal control, even at the cost of efficiency or collaboration."
              },
              {
                "age_when": 44,
                "event": "During the 2015 Chennai floods, two colleagues who had invested heavily in equity markets saw significant losses while her conservative laddered fixed deposit and debt fund portfolio remained intact.",
