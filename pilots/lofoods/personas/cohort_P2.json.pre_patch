          "replacement": "cross-checking prices across BigBasket and Spencer's",
          "attribute_source": "location.city (Chennai metro), income_bracket (middle)"
        },
        {
          "original": "aggressive crypto portfolio during a market crash",
          "replacement": "aggressive crypto losses that reinforced reliance on HDFC fixed deposits",
          "attribute_source": "life_story (age 26 incident), income_bracket (middle, conservative)"
        },
        {
          "original": "mapping options against perceived value",
          "replacement": "mapping options across BigBasket, Spencer's, and D-Mart",
          "attribute_source": "location.city (Chennai), income_bracket (middle)"
        }
      ],
      "validation_status": {
        "cr1_isolation": "pass",
        "cr2_stereotype_audit": "not_run",
