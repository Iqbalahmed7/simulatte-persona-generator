  "sarvam_enrichment": [
    {
      "enrichment_applied": true,
      "enrichment_provider": "sarvam",
      "enrichment_scope": "narrative_and_examples",
      "persona_id": "pg-pg-002",
      "enriched_narrative": {
        "first_person": "I still remember the contaminated batch incident \u2014 it changed everything about how I buy anything my family consumes. I don't cut corners on quality, period. Price barely registers for me; what I need is verified certifications, transparent ingredient lists, and a brand I've personally vetted over time. Once I find that brand, I stay. Switching isn't something I do casually.\n\nBut here's my honest tension: I want to cross-check every label on Blinkit or at my local Naturals outlet, control every purchase decision \u2014 yet I constantly catch myself messaging my peers in our WhatsApp group what they're using, almost craving someone I trust to just tell me it's safe. I'm drawn to brands my peer circle already believes in.\n\nI'll still verify it myself. I always do. But knowing someone I respect already trusts a brand? That moves me faster than any advertisement ever could.",
        "third_person": "Priya Sharma is a 34-year-old postgraduate professional navigating early motherhood in Mumbai while maintaining a demanding full-time career in the pharma sector. Her decision-making is shaped profoundly by a past encounter with a contaminated product batch \u2014 an experience that permanently recalibrated her purchasing psychology toward rigorous quality verification and third-party certifications. She now treats ingredient transparency and lab-tested sourcing as non-negotiable prerequisites, not optional reassurances.\n\nPriya's analytical disposition means she systematically evaluates information across trusted retail channels\u2014Naturals, premium supermarkets, verified e-commerce platforms\u2014before committing. Yet this thoroughness coexists with a persistent tension: she desires control over household decisions but finds herself gravitating toward trusted peers within her WhatsApp mother circles for validation, revealing an underlying need for social confirmation. This dynamic explains why peer recommendations carry disproportionate weight despite her self-directed research habits. Her very high brand loyalty is not blind allegiance\u2014it is earned trust, maintained through consistent quality signals. Because price sensitivity is low, she readily absorbs premium costs to stay within brands she has already vetted. Switching carries psychological risk she considers unacceptable, making familiarity and reliability her ultimate purchasing currency."
      },
      "cultural_references_added": [
        "Blinkit (Mumbai quick-commerce platform)",
        "Naturals (regional health retail chain in Maharashtra)",
        "WhatsApp group (peer network communication channel)",
        "pharma sector (specific to Mumbai employment context)"
      ],
      "contextual_examples_replaced": [
        {
          "original": "a supermarket",
          "replacement": "Naturals or premium supermarket outlets",
          "attribute_source": "location.city + income_bracket"
        },
        {
          "original": "asking my close friends what they're using",
          "replacement": "messaging my peers in our WhatsApp group",
          "attribute_source": "life_stage.early-family + location.metro"
        },
