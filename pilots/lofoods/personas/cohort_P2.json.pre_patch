            "life_defining_events": [
              {
                "age_when": 27,
                "event": "Priya discovered that a popular protein supplement she had been recommending to colleagues at her pharma firm was linked to a contamination recall \u2014 a brand she had trusted based on marketing alone, not lab data.",
                "lasting_impact": "This incident hardened her into a quality-first buyer who now demands verified certifications and ingredient transparency before purchasing any consumable product, regardless of brand reputation or price."
              },
              {
                "age_when": 32,
                "event": "After meticulously creating a typed daily routine and feeding schedule for her infant daughter, Priya returned from work to find the nanny had improvised the meals and skipped the structured nap window entirely, citing the baby's mood.",
                "lasting_impact": "The experience deepened her control-versus-delegation tension, making her reluctant to outsource decisions involving her child's wellbeing and driving her to systematize household protocols in exhaustive detail."
              },
              {
                "age_when": 30,
                "event": "When researching air purifiers before her daughter's birth, Priya ignored two expert blog recommendations after a trusted colleague's mothers' group shared consistent, specific complaints about the same models' filter replacement costs.",
