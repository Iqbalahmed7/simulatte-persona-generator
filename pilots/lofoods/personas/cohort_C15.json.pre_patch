          "original": "not influencers, but people I trust",
          "replacement": "not Instagram influencers, but people I trust who've made the same mistake",
          "attribute_source": "behavioral_summary.peer_influenced, age_28_professional"
        },
        {
          "original": "comparing options obsessively",
          "replacement": "comparing options obsessively, usually checking reviews on Flipkart or asking the group chat",
          "attribute_source": "location.metro_context, behavioral_summary.analytical"
        },
        {
          "original": "wait for the right moment, the right deal",
