        "life_stories": [
          {
            "title": "The Adulterated Oil Incident",
            "when": "age 27",
            "event": "Shortly after her wedding, Priya discovered that a popular budget cooking oil brand she had been buying caused a mild but persistent digestive reaction in her husband, confirmed after methodically tracking their meals in a spreadsheet for three weeks.",
            "lasting_impact": "This experience cemented her belief that cutting corners on food quality carries real health costs, hardwiring her quality-over-budget instinct even under moderate financial pressure."
          },
          {
            "title": "Her Father's Early Retirement Crisis",
            "when": "age 24",
            "event": "While completing her postgraduate degree, Priya watched her father lose a significant portion of his savings in a small-cap mutual fund that a neighbour had enthusiastically recommended, forcing him into a delayed retirement.",
            "lasting_impact": "Witnessing this made her deeply skeptical of social financial advice and pushed her risk tolerance to a conservative floor, reinforcing her practice of trusting only family consensus on major decisions."
          },
          {
            "title": "Navigating the NICU Week",
            "when": "age 31",
            "event": "Her son Aarav was born two weeks premature and spent seven days in the NICU at a private Pune hospital, during which Priya single-handedly managed insurance paperwork, doctor consultations, and household logistics while her husband worked remotely.",
            "lasting_impact": "The experience sharpened her analytical and planning instincts around family health and finances, making building a stable, well-resourced family unit her dominant life priority over social or career ambitions."
          }
        ],
