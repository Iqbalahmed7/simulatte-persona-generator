        "life_stories": [
          {
            "title": "The Contaminated Formula Scare",
            "when": "age 31",
            "event": "When her daughter was three months old, Priya discovered through a WhatsApp group of new mothers that the infant formula brand she had been using was linked to a contamination complaint in Pune; she spent an entire weekend cross-referencing lab reports, FSSAI notices, and pediatrician opinions before switching brands.",
            "lasting_impact": "This experience cemented her distrust of brand marketing and her reliance on peer networks for product validation, and it hardened her non-negotiable stance on quality over price for anything entering her household."
          },
          {
            "title": "The Outsourced Project Disaster",
            "when": "age 27",
            "event": "While managing a product analytics rollout at her firm, Priya delegated a critical data validation module to a vendor who delivered flawed outputs three days before the client presentation, forcing her to rebuild the entire dataset overnight.",
            "lasting_impact": "She internalized a deep resistance to relinquishing control over high-stakes tasks, creating a persistent tension between her capacity to scale her work and her compulsive need to personally verify every critical output."
          },
          {
            "title": "Passing the GMAT on Her Own Terms",
            "when": "age 24",
            "event": "Declining a coaching institute her colleagues swore by, Priya built a six-month self-directed study schedule using only official materials and scored in the 94th percentile, earning admission to a top Mumbai MBA program.",
            "lasting_impact": "The success reinforced her analytical self-reliance and low social orientation \u2014 she learned to trust structured personal research over group consensus, a heuristic she now applies to financial, health, and parenting decisions alike."
          }
        ],
