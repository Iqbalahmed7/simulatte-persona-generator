# ─── Required ────────────────────────────────────────────────────────────
# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Postgres connection string (required for the standalone v1 service).
# Railway's Postgres plugin populates this automatically when linked.
DATABASE_URL=postgresql://user:pass@host:5432/persona_generator

# Shared secret for /v1/* endpoint auth. Required in production.
# When unset, /v1/* endpoints accept anonymous calls (dev mode only).
INTERNAL_API_KEY=replace-with-32-byte-random-hex

# ─── Optional ────────────────────────────────────────────────────────────
# Sarvam API key (optional — enables Sarvam-powered Indian persona generation)
SARVAM_API_KEY=your_sarvam_api_key_here

# Server / runtime
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
LOG_LEVEL=INFO

# Worker tuning
WORKER_POLL_INTERVAL=5

# Legacy filesystem cohort store (kept as fallback for /generate, /cohort/{id})
COHORT_STORE_DIR=/tmp/simulatte_cohorts
