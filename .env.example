# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Sarvam API key (optional — enables Sarvam-powered Indian persona generation)
# Get yours at: https://api.sarvam.ai
# When set, Indian personas (country=India) are generated using Sarvam's sarvam-m model
# When not set, falls back to Claude Haiku for Indian persona generation
SARVAM_API_KEY=your_sarvam_api_key_here

# API server config
API_HOST=0.0.0.0
API_PORT=8000

# Cohort storage directory (FastAPI microservice stores cohorts here)
COHORT_STORE_DIR=/tmp/simulatte_cohorts
